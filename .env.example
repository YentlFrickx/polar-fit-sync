# Polar OAuth credentials — obtain from https://admin.polaraccesslink.com
# Copy this file to .env and fill in real values before running docker compose up
POLAR_CLIENT_ID=your-polar-client-id
POLAR_CLIENT_SECRET=your-polar-client-secret
POLAR_REDIRECT_URI=http://localhost:8080/oauth/callback

# Optional: set to the public base URL of this service (required for webhook mode)
# PFS_BASE_URL=https://your-domain.example.com

# Optional: required when PFS_SYNC_MODE is webhook or both
# PFS_WEBHOOK_SECRET=your-webhook-secret

# Optional overrides (defaults shown)
# PFS_SYNC_MODE=poll
# PFS_SYNC_INTERVAL_MINUTES=60
# PFS_DB_PATH=/data/state.db
# PFS_OUTPUT_DIR=/data/fit
# PFS_MEMBER_ID=polar-fit-sync
# PFS_LOG_LEVEL=INFO
